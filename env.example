# ============================================
# Daily Rewards System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!
# ============================================

# ============================================
# SUBGRAPH URLs
# ============================================

# Main GEB subgraph for querying protocol data
GEB_SUBGRAPH_URL=https://your-subgraph-url/api

# LP-specific subgraph (optional, defaults to GEB_SUBGRAPH_URL)
LP_GEB_SUBGRAPH_URL=

# Minter-specific subgraph (optional, defaults to GEB_SUBGRAPH_URL)
MINTER_GEB_SUBGRAPH_URL=

# Uniswap V3 subgraph for pool data
UNISWAP_SUBGRAPH_URL=https://gateway.thegraph.com/api/YOUR_API_KEY/subgraphs/id/...

# stKITE subgraph
STKITE_SUBGRAPH_URL=https://your-stkite-subgraph-url/api

# HAI-VELO subgraph
HAIVELO_SUBGRAPH_URL=https://your-haivelo-subgraph-url/api

# LP Staking subgraph (for HaiBoldCurveLPStaking and HaiVeloVeloLPStaking data)
LP_STAKING_SUBGRAPH_URL=https://your-lp-staking-subgraph-url/api

# Reward Distributor subgraph
DISTRIBUTOR_SUBGRAPH_URL=https://your-distributor-subgraph-url/api

# Optional JSON ledger of approved returned overpayments.
# Amounts must be wei-denominated token amounts and entries must include returnTx.
CLAIM_ADJUSTMENTS_FILE=

# ============================================
# CONTRACT ADDRESSES
# ============================================

# Uniswap V3 pool address for HAI
UNISWAP_POOL_ADDRESS=0x146b020399769339509c98B7B353d19130C150EC

# OP Standard Bridge
STANDARD_BRIDGE_ADDRESS=0x4200000000000000000000000000000000000010

# LayerZero executor
LZ_EXECUTOR_ADDRESS=0xe93685f3bba03016f02bd1828badd6195988d950

# Cross-domain messenger
CROSS_DOMAIN_MESSENGER_ADDRESS=0x36BDE71C97B33Cc4729cf772aE268934f7AB70B2

# Collateral token addresses
APX_ETH_ADDRESS=0x16Ed8E219cde31E14a80dCb6C9127A5EC6e88e46
RETH_CONTRACT_ADDRESS=0x9bcef72be871e61ed4fbbc7630889bee758eb81d
WSTETH_CONTRACT_ADDRESS=0x1f32b1c2345538c0c6f582fcb022739c4a194ebb
HOP_PROTOCOL_RETH_WRAPPER=0x19B2162CA4C2C6F08C6942bFB846ce5C396aCB75

# Reward token addresses
KITE_ADDRESS=0xf467C7d5a4A9C4687fFc7986aC6aD5A4c81E1404
OP_ADDRESS=0x4200000000000000000000000000000000000042
DINERO_ADDRESS=0x09d9420332bff75522a45fcff4855f82a0a3ff50
HAI_ADDRESS=0x10398AbC267496E49106B07dd6BE13364D10dC71

# Reward Distributor contract
REWARD_DISTRIBUTOR_ADDRESS=0xfEd2eB6325432F0bF7110DcE2CCC5fF811ac3D4D

# ============================================
# NETWORK CONFIGURATION
# ============================================

# Primary RPC URL (Optimism mainnet)
RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Specific RPC URLs (optional, defaults to RPC_URL)
LP_RPC_URL=
MINTER_RPC_URL=
HAIVELO_RPC_URL=
LP_STAKING_RPC_URL=
DISTRIBUTOR_RPC_URL=

# Chain ID
CHAIN_ID=optimism

# ============================================
# BLOCK CONFIGURATION
# ============================================

# Generic start/end blocks (used as fallback)
START_BLOCK=136424800
END_BLOCK=

# Historic start block for LP rewards calculation
LP_HISTORIC_START_BLOCK=132012513

# Start block for daily LP rewards (end of historic period)
LP_START_BLOCK=136779976

# LP end block (usually set dynamically by entry script)
LP_END_BLOCK=

# Historic start block for HAI-VELO rewards
HAIVELO_HISTORIC_START_BLOCK=130991964

# Start block for daily HAI-VELO rewards
HAIVELO_START_BLOCK=136424800

# HAI-VELO end block (usually set dynamically by entry script)
HAIVELO_END_BLOCK=

# Minter rewards start block
MINTER_START_BLOCK=137678333

# Minter end block (usually set dynamically by entry script)
MINTER_END_BLOCK=

# LP Staking rewards start block
LP_STAKING_START_BLOCK=

# LP Staking end block (usually set dynamically by entry script)
LP_STAKING_END_BLOCK=

# ============================================
# REWARD CONFIGURATION
# ============================================

# --- LP Rewards ---

# Daily LP reward amounts per token (JSON format)
# Example: {"KITE": 100, "OP": 50}
REWARD_LP_CONFIG={"KITE": 100}

# Historic LP reward amounts (distributed once between LP_HISTORIC_START_BLOCK and LP_START_BLOCK)
# Example: {"OP": 8250}
REWARD_LP_HISTORIC_CONFIG={"OP": 8250}

# Collateral types considered for LP rewards
# Example: ["WETH", "WSTETH", "OP"]
REWARD_LP_COLLATERAL_TYPES=["WETH"]

# --- Minter Rewards ---

# Daily minter reward amounts per token and collateral type (JSON format)
# Example: {"KITE":{"HAIVELO": 50, "ALETH": 50}}
REWARD_MINTER_CONFIG={"KITE":{"HAIVELO": 50, "ALETH": 50}}

# Minter collateral types
# Example: ["HAIVELO","ALETH","MSETH","YV-VELO-ALETH-WETH"]
REWARD_MINTER_COLLATERAL_TYPES=["HAIVELO","ALETH"]

# Multi-window minter reward configuration (overrides REWARD_MINTER_CONFIG if set)
# Format: Array of {startBlock, endBlock (optional), config}
# Example: [{"startBlock":137678333,"config":{"KITE":{"HAIVELO":50,"ALETH":50}}}]
REWARD_MINTER_WINDOWS=

# --- HAI-VELO Rewards ---

# Daily HAI-VELO reward amounts per token
# Example: {"OP": 100}
REWARD_HAIVELO_CONFIG={"OP": 100}

# Historic HAI-VELO reward amounts
# Example: {"HAI": 3578, "KITE": 278}
REWARD_HAIVELO_HISTORIC_CONFIG={"HAI": 3578, "KITE": 278}

# HAI-VELO collateral type identifiers
HAIVELO_COLLATERAL_TYPE_IDS=["HAIVELO","HAIVELOV2"]

# --- LP Staking Rewards ---
# For HaiBoldCurveLPStaking and HaiVeloVeloLPStaking rewards
# These rewards support KITE staking boost (ratio of staked KITE vs staked LP)

# Daily LP staking reward amounts per token and staking type (JSON format)
# Example: {"KITE":{"HAI_BOLD_CURVE": 50, "HAI_VELO_VELO": 50}}
REWARD_LP_STAKING_CONFIG={}

# LP staking types to consider (defaults to both if not set)
# Example: ["HAI_BOLD_CURVE", "HAI_VELO_VELO"]
REWARD_LP_STAKING_TYPES=["HAI_BOLD_CURVE", "HAI_VELO_VELO"]

# Multi-window LP staking reward configuration (overrides REWARD_LP_STAKING_CONFIG if set)
# Format: Array of {startBlock, endBlock (optional), config}
# Example: [{"startBlock":140000000,"config":{"KITE":{"HAI_BOLD_CURVE":50,"HAI_VELO_VELO":50}}}]
REWARD_LP_STAKING_WINDOWS=

# ============================================
# WALLET CONFIGURATION
# ============================================
# CRITICAL: Keep these values secret!

# Address authorized to set rewards on the distributor contract
REWARD_SETTER_ADDRESS=0x...

# Private key for the reward setter wallet
# WARNING: Never share this or commit it to version control!
REWARD_SETTER_PRIVATE_KEY=

# ============================================
# CLOUDFLARE KV STORAGE
# ============================================
# Used for storing Merkle trees

# Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=

# KV namespace ID for storing Merkle trees
CLOUDFLARE_NAMESPACE_ID=

# API token with KV write permissions
CLOUDFLARE_API_TOKEN=

# ============================================
# API KEYS
# ============================================

# Alchemy API key (for RPC and additional services)
ALCHEMY_API_KEY=

# Covalent API key (for transaction data)
COVALENT_API_KEY=

# ============================================
# DEPOSIT SERVICE (Optional)
# ============================================

# Deposit contract address
DEPOSIT_CONTRACT_ADDRESS=

# Address that sends deposits
DEPOSIT_SENDER_ADDRESS=

# Token address for deposits
DEPOSIT_TOKEN_ADDRESS=

# ============================================
# TELEGRAM NOTIFICATIONS (Optional)
# ============================================

# Telegram bot token from BotFather
# Create a bot: https://t.me/botfather
TELEGRAM_BOT_TOKEN=

# Path to store user subscriptions (defaults to ./telegram-users.json)
TELEGRAM_CHAT_STORAGE_FILE=./telegram-users.json

# ============================================
# DEBUGGING (Optional)
# ============================================

# Enable debug mode (true/false or 1/0)
DEBUG_REWARDS=false

# Custom debug output directory (defaults to ./debug-data)
DEBUG_OUTPUT_DIR=./debug-data
