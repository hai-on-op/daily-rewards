{
  "name": "daily-rewards",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:claimed-amounts": "jest src/services/claimed-amounts/__tests__/",
    "test-telegram": "ts-node src/test-telegram.ts",
    "telegram-bot": "ts-node src/modules/on-chain.ts",
    "telegram-bot:prod": "yarn build && node dist/modules/on-chain.js",
    "entry": "ts-node src/modules/orchestrator/cli.ts",
    "entry:prod": "yarn build && node dist/modules/orchestrator/cli.js",
    "entry:dev": "FEATURE_MODE=development ts-node src/modules/orchestrator/cli.ts",
    "entry:dry-run": "FEATURE_MODE=dry-run ts-node src/modules/orchestrator/cli.ts",
    "entry:legacy": "ts-node src/modules/entry.ts",
    "entry:legacy:prod": "yarn build && node dist/modules/entry.js",
    "debug-viewer": "cd debug-viewer && VITE_DEBUG_DATA_DIR=../debug-data yarn dev",
    "verify-positions": "ts-node src/scripts/verify-positions-report.ts",
    "daily-report": "ts-node src/scripts/daily-reward-report.ts",
    "report-api": "ts-node src/scripts/report-api.ts",
    "report-api:prod": "yarn build && node dist/scripts/report-api.js",
    "audit:claim-overpayments": "ts-node src/scripts/audit-claim-overpayments.ts",
    "audit:bad-claims": "ts-node src/scripts/audit-bad-claims.ts",
    "verify-viewer": "cd verify-viewer && yarn dev",
    "report-viewer": "cd report-viewer && yarn dev",
    "golden:record": "ts-node src/scripts/golden-master.ts --record",
    "golden:verify": "ts-node src/scripts/golden-master.ts --verify"
  },
  "dependencies": {
    "@covalenthq/client-sdk": "^2.2.1",
    "@openzeppelin/merkle-tree": "^1.0.7",
    "alchemy-sdk": "^3.5.8",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "ethers": "^5.7.2",
    "node-telegram-bot-api": "^0.66.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^22.5.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2"
  }
}
